# Port the container listens on (host network mode → binds directly on host)
PORT=8090

# Host paths that get mounted into the container.
#
# SCRIPTS_HOST_PATH: 시나리오 스크립트 경로. 레포에 포함된 서비스별 경로가 기본값.
#   - plopvape-shop (기본): ./scenarios/services/plopvape-shop/scripts
#   - 다른 서비스로 바꾸려면 ./scenarios/services/<서비스명>/scripts 로 변경
#   - 레포 밖 경로를 써야 할 경우에만 절대경로 지정
SCRIPTS_HOST_PATH=./scenarios/services/plopvape-shop/scripts
KUBECONFIG_HOST_PATH=/home/nkia/.kube
LOGS_HOST_PATH=./logs
